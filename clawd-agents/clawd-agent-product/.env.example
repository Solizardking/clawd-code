# CLAWD Agent Product — Environment Configuration
# Copy to .env, fill in values. NEVER commit the filled file.

# Solana RPC (Helius recommended for DAS)
RPC_URL=https://mainnet.helius-rpc.com/?api-key=<YOUR_HELIUS_KEY>

# Wallet keypair (base58 or JSON array). Use a dedicated hot wallet.
WALLET_SECRET_KEY=<YOUR_BASE58_PRIVATE_KEY>

# Registration URI — set after uploading clawd-registration.json
REGISTRATION_URI=<IRYS_URI_FROM_UPLOAD_METADATA>

# Collection metadata URI (optional)
COLLECTION_URI=https://x402.wtf/assets/clawd-collection.json

# Agent asset metadata URI (optional)
ASSET_URI=https://x402.wtf/assets/clawd-agent.json

# $CLAWD token mint address
CLAWD_MINT=8cHzQHUS2s2h8TzCmfqPKYiM4dSt4roa3n7MyRLApump

# Minimum $CLAWD balance required for SSO auth
MIN_CLAWD_UI_AMOUNT=1

# Session TTL in seconds
SESSION_TTL_SECONDS=3600

# Session signing secret (openssl rand -hex 32)
SESSION_SECRET=dev-only-change-me

# SSO server port
PORT=8787