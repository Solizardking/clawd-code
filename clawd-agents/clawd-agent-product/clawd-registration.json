    "clawdAuthSso": {
      "scheme": "CLAWD_AUTH_V1",
      "description": "A user proves control of a wallet, proves the wallet holds $CLAWD, and proves ownership or delegation of a registered Clawd MPL Core agent. The verifier issues a short-lived session token usable as SSO across x402.wtf, clawdrouter, and MCP/A2A services.",
      "credentialType": "clawd-token-plus-agent-mint",
      "proofRequirements": [
        {
          "name": "wallet-signature",
          "description": "Wallet signs a one-time challenge containing wallet, agent asset, domain, nonce, and expiry."
        },
        {
          "name": "clawd-token-holding",
          "description": "Verifier confirms the wallet holds at least minimumBalanceUiAmount of $CLAWD."
        },
        {
          "name": "registered-agent-asset",
          "description": "Verifier confirms the supplied agent asset has a Metaplex AgentIdentity record and registration document."
        },
        {
          "name": "agent-owner-or-delegate",
          "description": "Verifier confirms the wallet owns the agent asset or has an authorized execution delegation/creator proof."
        }
      ],
      "session": {
        "issuer": "https://x402.wtf",
        "audience": [
          "https://x402.wtf",
          "https://clawdrouter.fly.dev"
        ],
        "ttlSeconds": 3600,
        "claims": [
          "wallet",
          "agentAsset",
          "clawdMint",
          "clawdBalance",
          "agentIdentityPda",
          "assetSignerPda",
          "tier",
          "permissions",
          "issuedAt",
          "expiresAt"
        ]
      },
      "endpoints": {
        "challenge": "https://x402.wtf/api/auth/challenge",
        "verify": "https://x402.wtf/api/auth/verify",
        "session": "https://x402.wtf/api/auth/session",
        "logout": "https://x402.wtf/api/auth/logout"
      },
      "tiers": [
        {
          "name": "holder",
          "minimumClawd": 1,
          "permissions": [
            "catalog.read",
            "agent.spawn.prepare",
            "x402.discount.basic"
          ]
        },
        {
          "name": "operator",
          "minimumClawd": 1000,
          "permissions": [
            "catalog.read",
            "agent.spawn",
            "mcp.metered",
            "x402.discount.operator"
          ]
        },
