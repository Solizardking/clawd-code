NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
CLAWD_API_URL=http://localhost:3001

# Provider keys — server-side fallback used when a request has no client-supplied key.
# Z.AI is the default provider across the CLI, Telegram relay, and this UI.
ZAI_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# Telegram relay (configured/started via the CLI: `clawd-code telegram`, not this web app)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=
