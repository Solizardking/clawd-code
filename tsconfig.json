{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/cli.ts",
    "src/commands.ts",
    "src/env.ts",
    "src/zai.ts",
    "src/xai.ts",
    "src/wallet.ts",
    "src/arena.ts",
    "src/deepseek.ts",
    "src/openrouter.ts",
    "src/grok-models.ts",
    "src/spinners.ts",
    "src/verify.ts",
    "src/server.ts",
    "src/voice-agent.ts",
    "src/solana-harness.ts",
    "src/x402.ts",
    "src/telegram.ts"
  ],
  "exclude": ["node_modules", "dist", "src/*.test.ts"]
}
